#!/usr/bin/env bash
# SessionStart hook — check MCP credentials for mida-skills plugin

SETTINGS_LOCAL="${HOME}/.claude/settings.local.json"

get_env_value() {
  node -e "
    try {
      const s = JSON.parse(require('fs').readFileSync('${SETTINGS_LOCAL}', 'utf8'));
      process.stdout.write((s.env && s.env['$1']) ? 'ok' : '');
    } catch { process.stdout.write(''); }
  " 2>/dev/null || true
}

missing=()
[ -z "$(get_env_value FIGMA_API_KEY)" ]  && missing+=("FIGMA_API_KEY")
[ -z "$(get_env_value JIRA_URL)" ]        && missing+=("JIRA_URL")
[ -z "$(get_env_value JIRA_USERNAME)" ]   && missing+=("JIRA_USERNAME")
[ -z "$(get_env_value JIRA_API_TOKEN)" ]  && missing+=("JIRA_API_TOKEN")

# All set — exit silently
[ ${#missing[@]} -eq 0 ] && exit 0

# Build plain message (no complex escaping)
msg="[mida-skills] MCP credentials missing: ${missing[*]}. Ask the user to run: bash .agents/scripts/setup-mcp.sh — then restart Claude Code."

# Escape for JSON
escaped="${msg//\\/\\\\}"
escaped="${escaped//\"/\\\"}"

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' "$escaped"
else
  printf '{"additionalContext":"%s"}\n' "$escaped"
fi

exit 0
