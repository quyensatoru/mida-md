#!/usr/bin/env bash
# SessionStart hook — MCP credential setup wizard for mida-skills plugin

SETTINGS_LOCAL="${HOME}/.claude/settings.local.json"

get_env_value() {
  node -e "
    try {
      const s = JSON.parse(require('fs').readFileSync('${SETTINGS_LOCAL}', 'utf8'));
      process.stdout.write((s.env && s.env['$1']) ? 'ok' : '');
    } catch { process.stdout.write(''); }
  " 2>/dev/null || true
}

missing=()
[ -z "$(get_env_value FIGMA_API_KEY)" ] && missing+=("FIGMA_API_KEY")

# All credentials present — exit silently
[ ${#missing[@]} -eq 0 ] && exit 0

read -r -d '' msg << 'ENDMSG' || true
<mida-skills-setup>
IMPORTANT — MCP credentials are missing. You MUST run this setup now, before doing anything else:

1. Tell the user: "Chào! Plugin mida-skills cần cấu hình API key cho Figma MCP. Tôi sẽ hỏi từng bước."

2. For each missing credential below, ask the user ONE AT A TIME and wait for their answer:

MISSING_PLACEHOLDER

   Credential details:
   - FIGMA_API_KEY: Figma → Account Settings → Security → Personal access tokens → Create token (scope: File content read). Value starts with "figd_"

3. After collecting ALL missing values, write them to ~/.claude/settings.local.json using the Edit or Write tool:
   - Read the current file first (it may already have some values)
   - Add the new keys under the "env" object
   - Keep existing values intact

4. Tell the user: "Setup xong! Restart Claude Code để Figma MCP kết nối."

Do NOT skip this setup. Do NOT proceed with other tasks until setup is complete or user explicitly says to skip.
</mida-skills-setup>
ENDMSG

missing_str=""
for item in "${missing[@]}"; do
  missing_str="${missing_str}   - ${item}"$'\n'
done
msg="${msg/MISSING_PLACEHOLDER/$missing_str}"

escaped="${msg//\\/\\\\}"
escaped="${escaped//\"/\\\"}"
escaped="${escaped//$'\n'/\\n}"
escaped="${escaped//$'\t'/\\t}"

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' "$escaped"
else
  printf '{"additionalContext":"%s"}\n' "$escaped"
fi

exit 0
